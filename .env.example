# Music Deduplication Configuration
# Copy this file to .env and modify as needed

# Server settings
MUSIC_DEDUP_HOST=127.0.0.1
MUSIC_DEDUP_PORT=8000
MUSIC_DEDUP_DEBUG=false

# Backup settings
MUSIC_DEDUP_BACKUP_DIR=~/.music_deduper/backups

# AI settings
MUSIC_DEDUP_AI_DEFAULT_URL=
MUSIC_DEDUP_AI_DEFAULT_MODEL=gpt-4o-mini

# Logging settings
MUSIC_DEDUP_LOG_LEVEL=INFO
MUSIC_DEDUP_LOG_FILE=music_deduper.log

# Security settings (comma-separated)
MUSIC_DEDUP_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:8000,http://127.0.0.1:8000

# Timeout settings (seconds)
MUSIC_DEDUP_MAX_SCAN_TIMEOUT=300
MUSIC_DEDUP_MAX_EXECUTE_TIMEOUT=600
